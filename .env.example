# Kochi One API (kochi_one_server).
# Local: API_BASE_URL=http://localhost:3000 (run kochi_one_server; npm run dev or node server.js).
# Production: https://api.kochi.one — only after deploying code that includes routes under /api/aakriti/portal/.
API_BASE_URL=http://localhost:3000
PORT=3005

# Optional. Defaults to API_BASE_URL + /aakriti-logo.png (file must exist under kochi_one_server/public/).
# LOGO_URL=https://api.kochi.one/aakriti-logo.png

# Staff/admin login page: http://localhost:3005/login → uses API for /api/aakriti/portal/*
