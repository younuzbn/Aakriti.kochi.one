# Kochi One API (kochi_one_server). Use http://localhost:3000 when the API runs on this machine.
# https://api.kochi.one only works after that server has the /api/aakriti/portal/* routes deployed.
API_BASE_URL=https://localhost:3443
PORT=3005

# Optional. Defaults to API_BASE_URL + /aakriti-logo.png (file must exist under kochi_one_server/public/).
# LOGO_URL=https://api.kochi.one/aakriti-logo.png

# Staff/admin login page: http://localhost:3005/login → uses API for /api/aakriti/portal/*
